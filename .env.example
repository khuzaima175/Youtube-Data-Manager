# ─── YouTube Data API v3 ─────────────────────────────────────────────────────
# Get your key at: https://console.cloud.google.com → Enable YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key_here

# ─── Supabase ────────────────────────────────────────────────────────────────
# https://supabase.com → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Local dev: leave as-is.
# Railway: add your deployed URL e.g. https://your-app.up.railway.app
ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000

# ─── Server ──────────────────────────────────────────────────────────────────
# Railway sets PORT automatically — do NOT set this manually on Railway.
# For local dev this defaults to 5000 if unset.
PORT=5000

# Set to 1 to enable Flask debug mode (development only — never in production)
FLASK_DEBUG=0
